# --- Core ---
TEST_DIR=src/tests
TIMEOUT=120000
ACTION_TIMEOUT=60000
TIMEOUT_VISIBLE_LOCATOR=60000
RETRIES=1
HEADLESS=false
IGNOREHTTPSERRORS=true
FULLY_PARALLEL=true
BASE_URL=https://<BASE_URL>
WORKERS=4
MAX_FAILURES=1000
DOWNLOAD_PATH=tmp
TEACH_MODE=true

# --- Test user (example, fill under your system) ---
TEST_USER=
TEST_PASSWORD=

